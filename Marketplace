          <div class="timesheet-grid"><div class="ts-header"></div><div class="ts-header">Mon 10</div><div class="ts-header">Tue 11</div><div class="ts-header">Wed 12</div><div class="ts-header">Thu 13</div><div class="ts-header">Fri 14</div><div class="ts-header">Total</div><div class="ts-row-label">Regular</div><div class="ts-cell filled" onclick="toggleCell(this)">8</div><div class="ts-cell filled" onclick="toggleCell(this)">8</div><div class="ts-cell filled" onclick="toggleCell(this)">8</div><div class="ts-cell filled" onclick="toggleCell(this)">7</div><div class="ts-cell filled" onclick="toggleCell(this)">8</div><div class="ts-cell total">39</div><div class="ts-row-label">Overtime</div><div class="ts-cell" onclick="toggleCell(this)">—</div><div class="ts-cell" onclick="toggleCell(this)">—</div><div class="ts-cell filled" onclick="toggleCell(this)">2</div><div class="ts-cell" onclick="toggleCell(this)">—</div><div class="ts-cell" onclick="toggleCell(this)">—</div><div class="ts-cell total">2</div></div>
          <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center"><div style="font-size:13px;color:var(--slate)">Week total: <strong>41 hours</strong> · Day rate: <strong>₹18,000</strong></div><div style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800">Week total: <span style="color:var(--teal)">₹94,500</span></div></div>
        </div>
      </div>

      <!-- INVOICES -->
      <div class="page" id="page-invoices">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px"><div class="stats-row" style="grid-template-columns:repeat(3,180px);margin-bottom:0"><div class="stat-card teal" style="padding:14px 16px"><div class="stat-label">Total Earned</div><div class="stat-value" style="font-size:22px">₹12.4L</div><div class="stat-delta delta-up">This year</div></div><div class="stat-card amber" style="padding:14px 16px"><div class="stat-label">Pending</div><div class="stat-value" style="font-size:22px">₹1.8L</div><div class="stat-delta" style="color:var(--amber)">3 invoices</div></div><div class="stat-card coral" style="padding:14px 16px"><div class="stat-label">Overdue</div><div class="stat-value" style="font-size:22px">₹0</div><div class="stat-delta delta-up">All clear</div></div></div><button class="btn-app btn-app-primary" onclick="showToast('Invoice draft created.')">+ New Invoice</button></div>
        <div class="activity-panel" style="border-radius:14px">
          <div style="display:grid;grid-template-columns:90px 1fr 130px 100px 80px;gap:8px;padding:0 0 10px;border-bottom:1px solid var(--border);margin-bottom:4px"><div style="font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Invoice</div><div style="font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Mission / Client</div><div style="font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Period</div><div style="font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Amount</div><div style="font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Status</div></div>
          <div style="display:grid;grid-template-columns:90px 1fr 130px 100px 80px;gap:8px;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)"><div style="font-size:12px;font-weight:600">#INV-0092</div><div style="font-size:12.5px;color:var(--slate)">PV Automation · Sanofi</div><div style="font-size:12px;color:var(--muted)">Jun 10–14</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:13px">₹94,500</div><span class="invoice-status pending">Pending</span></div>
          <div style="display:grid;grid-template-columns:90px 1fr 130px 100px 80px;gap:8px;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)"><div style="font-size:12px;font-weight:600">#INV-0091</div><div style="font-size:12.5px;color:var(--slate)">PV Automation · Sanofi</div><div style="font-size:12px;color:var(--muted)">Jun 3–7</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:13px">₹90,000</div><span class="invoice-status paid">Paid</span></div>
          <div style="display:grid;grid-template-columns:90px 1fr 130px 100px 80px;gap:8px;align-items:center;padding:10px 0"><div style="font-size:12px;font-weight:600">#INV-0089</div><div style="font-size:12.5px;color:var(--slate)">GCC Strategy · Deloitte</div><div style="font-size:12px;color:var(--muted)">May 1–31</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:13px">₹3,24,000</div><span class="invoice-status paid">Paid</span></div>
        </div>
      </div>

      <!-- NOTIFICATIONS -->
      <div class="page" id="page-notifications">
        <div class="activity-panel" style="border-radius:14px;max-width:600px">
          <div class="notif-item notif-unread"><div class="notif-icon-wrap" style="background:var(--teal-l)"><svg width="18" height="18" fill="none" viewBox="0 0 16 16"><circle cx="8" cy="6" r="3" stroke="#0AB9A0" stroke-width="1.5"/><path d="M2 13c0-2.761 2.686-5 6-5s6 2.239 6 5" stroke="#0AB9A0" stroke-width="1.5" stroke-linecap="round"/></svg></div><div><div class="notif-text"><strong>Ananya Krishnan</strong> applied to Pharma PV Automation Lead. AI score: 95%.<span>2 min ago</span></div></div></div>
          <div class="notif-item notif-unread"><div class="notif-icon-wrap" style="background:var(--violet-l)"><svg width="18" height="18" fill="none" viewBox="0 0 16 16"><path d="M8 1l2 5h5l-4 3 1.5 5L8 11l-4.5 3L5 9 1 6h5z" fill="#7C5CFC" opacity=".8"/></svg></div><div><div class="notif-text">AI matching complete for <strong>Clinical Data Scientist</strong>. 6 profiles ready.<span>18 min ago</span></div></div></div>
          <div class="notif-item"><div class="notif-icon-wrap" style="background:var(--amber-l)"><svg width="18" height="18" fill="none" viewBox="0 0 16 16"><rect x="1" y="2" width="14" height="12" rx="2" stroke="#F59E0B" stroke-width="1.5"/></svg></div><div><div class="notif-text"><strong>Rohan Mehta</strong> submitted timesheet for Week 24.<span>1 hr ago</span></div></div></div>
          <div class="notif-item"><div class="notif-icon-wrap" style="background:var(--teal-l)"><svg width="18" height="18" fill="none" viewBox="0 0 16 16"><path d="M3 2h8l3 3v9a1 1 0 01-1 1H3a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="#0AB9A0" stroke-width="1.5"/></svg></div><div><div class="notif-text">Invoice <strong>#INV-0089</strong> paid — ₹3,24,000 credited.<span>Yesterday</span></div></div></div>
