<!-- MODALS -->
<div class="modal-backdrop" id="mission-modal"><div class="modal"><div class="modal-header"><div class="modal-title" id="modal-mission-title">Mission Detail</div><button class="close-btn" onclick="closeModal('mission-modal')">✕</button></div><div id="modal-mission-body"></div></div></div>
<div class="modal-backdrop" id="expert-modal"><div class="modal"><div class="modal-header"><div class="modal-title">Expert Profile</div><button class="close-btn" onclick="closeModal('expert-modal')">✕</button></div><div id="modal-expert-body"></div></div></div>
<div class="modal-backdrop" id="profile-modal"><div class="modal"><div class="modal-header"><div class="modal-title">My Profile</div><button class="close-btn" onclick="closeModal('profile-modal')">✕</button></div><div class="profile-section"><div class="talent-avatar" style="background:linear-gradient(135deg,var(--teal),var(--violet));width:60px;height:60px;border-radius:16px;font-size:20px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;color:white;flex-shrink:0">RS</div><div><div style="font-family:'Syne',sans-serif;font-size:16px;font-weight:700;margin-bottom:3px">Rahul Sharma</div><div style="font-size:13px;color:var(--muted);margin-bottom:6px">Big 4 Consultant · GCC Practice Lead</div><div style="font-size:12px;color:var(--slate)">Hyderabad · Member since 2023</div></div></div><div class="detail-grid"><div class="detail-item"><div class="detail-item-label">Missions managed</div><div class="detail-item-val">12 active</div></div><div class="detail-item"><div class="detail-item-label">Experts engaged</div><div class="detail-item-val">847</div></div></div><button class="btn-app btn-app-outline" style="width:100%">Edit Profile</button></div></div>

<div class="toast" id="toast"></div>

<script>
window.addEventListener('scroll', () => {
  document.getElementById('main-nav').classList.toggle('scrolled', window.scrollY > 10);
});

function launchPlatform() {
  document.getElementById('landing').style.display = 'none';
  document.getElementById('platform').style.display = 'block';
  document.getElementById('page-dashboard').classList.add('active');
}

function backToLanding() {
  document.getElementById('platform').style.display = 'none';
  document.getElementById('landing').style.display = 'block';
  window.scrollTo(0, 0);
}

const pages = { dashboard:'Dashboard', 'post-mission':'Post a Mission', 'talent-search':'Find Talent', missions:'My Missions', 'mission-board':'Mission Board', timesheet:'Timesheets', invoices:'Invoices', notifications:'Notifications' };

function navigate(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const p = document.getElementById('page-' + id);
  if (p) p.classList.add('active');
  document.getElementById('page-title').textContent = pages[id] || id;
  document.querySelectorAll('.nav-item').forEach(n => { if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'"+id+"'")) n.classList.add('active'); });
}

function switchRole(role, btn) {
  document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  navigate(role === 'expert' ? 'mission-board' : 'dashboard');
  showToast('Switched to ' + (role === 'expert' ? 'Expert' : 'Client') + ' view');
}

function activateChip(el) {
  el.closest('.filter-bar').querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}

function toggleCell(el) {
  el.classList.toggle('filled');
  el.textContent = el.classList.contains('filled') ? '8' : '—';
}

let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 16 16"><circle cx="8" cy="8" r="7" stroke="#0AB9A0" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="#0AB9A0" stroke-width="1.5" stroke-linecap="round"/></svg> ' + msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
}

function openModal(id) { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.modal-backdrop').forEach(bd => { bd.addEventListener('click', e => { if (e.target === bd) bd.classList.remove('show'); }); });

function openMissionModal(title, client, rate, status) {
  document.getElementById('modal-mission-title').textContent = title;
  const sc = status === 'Open' ? 'var(--teal)' : 'var(--amber)';
  document.getElementById('modal-mission-body').innerHTML = `<div class="detail-grid"><div class="detail-item"><div class="detail-item-label">Client</div><div class="detail-item-val">${client}</div></div><div class="detail-item"><div class="detail-item-label">Day Rate</div><div class="detail-item-val" style="color:var(--teal);font-family:'Syne',sans-serif;font-size:15px;font-weight:700">${rate}</div></div><div class="detail-item"><div class="detail-item-label">Status</div><div class="detail-item-val" style="color:${sc}">${status}</div></div><div class="detail-item"><div class="detail-item-label">Location</div><div class="detail-item-val">Hyderabad</div></div></div><div style="background:var(--surface);border-radius:10px;padding:14px;margin-bottom:16px;font-size:13px;color:var(--slate);line-height:1.7">Design and implement advanced automation solutions for this mission. You will work closely with global teams to deliver measurable business outcomes aligned with regulatory and operational requirements.</div><div style="display:flex;gap:8px"><button class="btn-app btn-app-primary" style="flex:1" onclick="closeModal('mission-modal');showToast('Shortlist opened')">View Proposals</button><button class="btn-app btn-app-outline" onclick="closeModal('mission-modal');showToast('Link copied.')">Share</button></div>`;
  openModal('mission-modal');
}

function openExpertModal(name, role, rate, score, avail, exp, skills) {
  const initials = name.split(' ').map(w => w[0]).join('');
  const colors = ['linear-gradient(135deg,#0AB9A0,#0891B2)','linear-gradient(135deg,#7C5CFC,#A855F7)','linear-gradient(135deg,#F59E0B,#F97316)','linear-gradient(135deg,#10B981,#059669)','linear-gradient(135deg,#EC4899,#BE185D)'];
  const color = colors[name.charCodeAt(0) % colors.length];
  const availLabel = avail==='now'?'<span class="avail-badge now">Available now</span>':avail==='soon'?'<span class="avail-badge soon">Available in 2 wks</span>':'<span class="avail-badge busy">On mission</span>';
  const skillTags = skills.split(', ').map(s=>`<span class="tag">${s}</span>`).join('');
  document.getElementById('modal-expert-body').innerHTML = `<div class="profile-section"><div class="talent-avatar" style="background:${color};width:56px;height:56px;border-radius:14px;font-size:18px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;color:white;flex-shrink:0">${initials}</div><div><div style="font-family:'Syne',sans-serif;font-size:16px;font-weight:700">${name}</div><div style="font-size:13px;color:var(--muted);margin-bottom:6px">${role}</div><div>${availLabel}</div></div></div><div class="ai-score" style="justify-content:flex-start;margin-bottom:14px"><svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2 5h5l-4 3 1.5 5L8 11l-4.5 3L5 9 1 6h5z"/></svg>AI Match Score: ${score}</div><div class="detail-grid"><div class="detail-item"><div class="detail-item-label">Day Rate</div><div class="detail-item-val" style="color:var(--teal);font-family:'Syne',sans-serif;font-weight:700">${rate}</div></div><div class="detail-item"><div class="detail-item-label">Experience</div><div class="detail-item-val">${exp}</div></div></div><div style="margin-bottom:16px"><div class="form-label" style="margin-bottom:8px">Key Skills</div><div class="mission-tags">${skillTags}</div></div><div style="display:flex;gap:8px"><button class="btn-app btn-app-primary" style="flex:1" onclick="closeModal('expert-modal');showToast('Invitation sent to ${name}!')">Invite to Mission</button><button class="btn-app btn-app-outline" onclick="showToast('Message sent.')">Message</button></div>`;
  openModal('expert-modal');
}

function openProfileModal() { openModal('profile-modal'); }
</script>
</body>
</html>
